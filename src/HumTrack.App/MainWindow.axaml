<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HumTrack.App.ViewModels"
        x:Class="HumTrack.App.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="HumTrack — Biomechanical Analysis"
        Background="#1A1A2E"
        Width="1280" Height="800"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="48,*,44">

        <!-- TOP TOOLBAR -->
        <Border Grid.Row="0" Background="#16213E">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="12,0">
                <Button x:Name="BtnLoad"      Content="📂  Load Video"  Click="OnLoadVideoClick"  VerticalAlignment="Center" Padding="12,6"/>
                <Button x:Name="BtnPlayPause" Content="{Binding PlayPauseText}" Command="{Binding PlayPauseCommand}" VerticalAlignment="Center" Width="90" Padding="0,6"/>
                <Button x:Name="BtnStop"      Content="⏹  Stop"         Command="{Binding StopCommand}" VerticalAlignment="Center" Padding="12,6"/>
                <TextBlock Text=" │ " Foreground="#444" VerticalAlignment="Center"/>
                <TextBlock Text="Markers: " Foreground="#888" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding MarkerCount}" Foreground="#E94560" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text=" │ " Foreground="#444" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="#AAAAAA"/>
            </StackPanel>
        </Border>

        <!-- VIDEO AREA: Panel stacks children; Image on bottom, Canvas on top -->
        <Border Grid.Row="1" Background="#0D1117" ClipToBounds="True">
            <Panel>
                <!-- The video frame -->
                <Image x:Name="VideoImage"
                       Source="{Binding CurrentFrame}"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       PointerPressed="OnVideoPointerPressed"/>

                <!-- Overlay canvas — children added in code-behind -->
                <Canvas x:Name="OverlayCanvas"
                        IsHitTestVisible="False"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                <!-- Placeholder hint (always visible; video frame renders over it) -->
                <TextBlock Text="📂  Load a video, then click on the markers you want to track"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#444444" FontSize="16"/>
            </Panel>
        </Border>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Background="#16213E">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="12,0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="Frame:" Foreground="#888" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentFrameIndex}" Foreground="#E94560" Width="48" VerticalAlignment="Center"/>
                    <TextBlock Text="/" Foreground="#555" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding MaximumFrameIndex}" Foreground="#888" Width="48" VerticalAlignment="Center"/>
                </StackPanel>
                <Slider Grid.Column="1" Value="{Binding CurrentFrameIndex}" Maximum="{Binding MaximumFrameIndex}"
                        IsEnabled="False" VerticalAlignment="Center" Margin="12,0"/>
                <TextBlock Grid.Column="2" Text="{Binding MetricsText}" Foreground="#888"
                           FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>
